          </div>
        </div>

        <div class="sequence-panel">
          <div class="demo-header">
            <div>
              <p class="section-kicker">Generated Temporal View</p>
              <h3>Senescence progression sequences</h3>
            </div>
            <div class="sequence-filters">
              <div class="sequence-filter-group sequence-dropdown" data-dropdown-group="tissue">
