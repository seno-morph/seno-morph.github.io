<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="title" content="SenMorph-X | A Multi-Tissue Benchmark for Senescence-Conditioned Cell Morphology Generation">
  <meta name="description" content="SenMorph-X presents real Xenium cell images, continuous senescence scores, and generated temporal morphology sequences across lung, prostate, and skin tissues.">
  <meta name="keywords" content="senescence, Xenium, spatial transcriptomics, cell morphology, temporal sequence, flow matching">
  <meta name="author" content="Your Team">
  <meta name="theme-color" content="#14452f">

  <title>SenMorph-X | Dataset Project Page</title>

  <link rel="icon" type="image/x-icon" href="static/images/favicon.ico">
  <link rel="apple-touch-icon" href="static/images/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="static/css/bulma.min.css">
  <link rel="stylesheet" href="static/css/index.css">
  <link rel="preload" href="static/css/fontawesome.all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript>
    <link rel="stylesheet" href="static/css/fontawesome.all.min.css">
  </noscript>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

  <script defer src="static/js/fontawesome.all.min.js"></script>
  <script defer src="static/js/index.js"></script>
</head>
<body>
  <button class="scroll-to-top" onclick="scrollToTop()" title="Scroll to top" aria-label="Scroll to top">
    <i class="fas fa-chevron-up"></i>
  </button>

  <main id="main-content">
    <section class="hero dataset-hero">
      <div class="hero-body">
        <div class="container is-max-desktop">
          <div class="eyebrow">NeurIPS 2026 Datasets &amp; Benchmarks</div>
          <div class="hero-story">
            <p class="hero-mini">Dataset + generation benchmark for cellular senescence</p>
            <h1 class="title publication-title">SenMorph-X: A Multi-Tissue Benchmark for Senescence-Conditioned Cell Morphology Generation</h1>
            <p class="hero-subtitle">
              SenMorph-X combines <strong>87,391</strong> real single-cell DAPI nuclear crops from three public Xenium tissue panels
              with <strong>continuous senescence scores</strong> and <strong>computationally generated temporal sequences</strong>,
              creating a benchmark for studying how cell morphology changes along senescence progression.
            </p>

            <div class="hero-ribbon">
              <span class="hero-tag">3 tissues: lung, prostate, skin</span>
              <span class="hero-tag">15 cell types</span>
              <span class="hero-tag">64 x 64 aligned DAPI crops</span>
              <span class="hero-tag">Flow Matching generation</span>
            </div>

            <div class="publication-links">
              <span class="link-block">
                <a href="#" class="external-link button is-normal is-rounded is-dark">
                  <span class="icon"><i class="fas fa-file-pdf"></i></span>
                  <span>Paper</span>
                </a>
              </span>
              <span class="link-block">
                <a href="#" class="external-link button is-normal is-rounded is-dark">
                  <span class="icon hf-icon">🤗</span>
                  <span>Dataset</span>
                </a>
              </span>
              <span class="link-block">
                <a href="#" class="external-link button is-normal is-rounded is-dark">
                  <span class="icon"><i class="fab fa-github"></i></span>
                  <span>Code</span>
                </a>
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-shell video-section">
      <div class="container is-max-desktop">
        <div class="video-shell">
          <div class="video-placeholder">
            <video controls preload="metadata" poster="">
              <source src="video.mp4" type="video/mp4">
            </video>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-shell overview-section">
      <div class="container is-max-desktop">
        <div class="overview-abstract">
          <h2 class="title is-3 overview-title">Abstract</h2>
          <p class="overview-copy">
            We collect <strong>87,391 single-cell DAPI nuclear crops</strong> from three publicly available Xenium tissue panels (lung, prostate, skin), and annotate each cell with a <strong>continuous senescence score</strong> computed from its gene expression profile using DeepScence. We introduce SenMorph-X to <strong>generate senescence-conditioned cell morphology with temporal changes</strong> based on the following images.
          </p>
        </div>
        <div class="overview-figure-card">
          <img class="overview-figure" src="figures/overview.png" alt="SenMorph-X data collection and generation overview">
        </div>
      </div>
    </section>
  
    <section class="section section-shell is-soft" id="dataset-demo">
      <div class="container is-max-desktop">
        <div class="section-heading">
          <h2 class="title is-3 demo-title">SenMorph-X Benchmark Demo</h2>
          <p class="section-copy demo-copy">
            SenMorph-X contains two complementary data views: <strong>real cross-sectional cell images</strong> from three Xenium tissue panels and computationally <strong>generated temporal sequences</strong> produced by our Flow Matching method.
          </p>
        </div>

        <div class="demo-overview-grid">
          <article class="summary-card">
            <span class="summary-value">87,391</span>
            <span class="summary-label">Real single-cell images</span>
          </article>
          <article class="summary-card">
            <span class="summary-value">3</span>
            <span class="summary-label">Xenium tissue panels</span>
          </article>
          <article class="summary-card">
            <span class="summary-value">15</span>
            <span class="summary-label">Unique cell types</span>
          </article>
          <article class="summary-card">
            <span class="summary-value">[0,1]</span>
            <span class="summary-label">Continuous senescence score</span>
          </article>
        </div>

        <div class="demo-layout">
          <div class="demo-main">
            <div class="demo-header">
              <div>
                <p class="section-kicker">Real Dataset View</p>
                <h3>Cross-sectional single-cell image cards</h3>
              </div>
              <div class="filter-pills">
                <span class="filter-pill active">All tissues</span>
                <span class="filter-pill">Lung</span>
                <span class="filter-pill">Prostate</span>
                <span class="filter-pill">Skin</span>
              </div>
            </div>

