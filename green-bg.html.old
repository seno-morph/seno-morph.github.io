                  <article class="cell-card">
                    <img class="cell-photo" src="images/image2.jpg" alt="Dataset sample 2">
                    <div class="cell-meta">
                      <div class="meta-row"><span>Tissue</span><strong>Prostate</strong></div>
                      <div class="meta-row"><span>Cell type</span><strong>Fibroblast</strong></div>
                      <div class="meta-row"><span>Score</span><strong>0.47</strong></div>
                    </div>
                  </article>
                  <article class="cell-card">
                    <img class="cell-photo" src="images/image (1).jpg" alt="Dataset sample 3">
                    <div class="cell-meta">
                      <div class="meta-row"><span>Tissue</span><strong>Skin</strong></div>
                      <div class="meta-row"><span>Cell type</span><strong>Immune</strong></div>
                      <div class="meta-row"><span>Score</span><strong>0.74</strong></div>
                    </div>
                  </article>
                  <article class="cell-card">
                    <img class="cell-photo" src="images/image (2).jpg" alt="Dataset sample 4">
                    <div class="cell-meta">
                      <div class="meta-row"><span>Tissue</span><strong>Lung</strong></div>
                      <div class="meta-row"><span>Cell type</span><strong>Endothelial</strong></div>
                      <div class="meta-row"><span>Score</span><strong>0.91</strong></div>
                    </div>
