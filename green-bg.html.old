                <button class="sequence-dropdown-toggle" type="button" data-dropdown-toggle="tissue" aria-expanded="false">
                  <span class="dropdown-value" data-dropdown-value="tissue">All</span>
                  <i class="fas fa-chevron-down"></i>
                </button>
                <div class="sequence-dropdown-menu" data-dropdown-menu="tissue">
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="tissue" value="all" checked>
                    <span>All</span>
                  </label>
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="tissue" value="lung">
                    <span>Lung</span>
                  </label>
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="tissue" value="prostate">
                    <span>Prostate</span>
                  </label>
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="tissue" value="skin">
                    <span>Skin</span>
