              </div>
              <div class="sequence-filter-group sequence-dropdown" data-dropdown-group="celltype">
                <span class="sequence-filter-label">Cell type</span>
                <button class="sequence-dropdown-toggle" type="button" data-dropdown-toggle="celltype" aria-expanded="false">
                  <span class="dropdown-value" data-dropdown-value="celltype">All</span>
                  <i class="fas fa-chevron-down"></i>
                </button>
                <div class="sequence-dropdown-menu" data-dropdown-menu="celltype">
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="celltype" value="all" checked>
                    <span>All</span>
                  </label>
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="celltype" value="epithelial">
                    <span>Epithelial</span>
                  </label>
                  <label class="sequence-check">
                    <input class="sequence-checkbox" type="checkbox" data-filter-group="celltype" value="fibroblast">
                    <span>Fibroblast</span>
                  </label>
                  <label class="sequence-check">
